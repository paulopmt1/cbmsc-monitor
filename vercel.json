{
  "version": 2,
  "builds": [
    {
      "src": "api/mcp.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/chat.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/chat-tools.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/log.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/mcp/?$",
      "dest": "/api/mcp.js"
    },
    {
      "src": "^/api/chat-tools/?$",
      "dest": "/api/chat-tools.js"
    },
    {
      "src": "^/api/chat/?$",
      "dest": "/api/chat.js"
    },
    {
      "src": "^/api/log/?$",
      "dest": "/api/log.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
