# Database Configuration
# Get your connection string from https://console.neon.tech (Neon) or use a standard PostgreSQL URL (Docker)
DATABASE_URL=postgresql://username:password@ep-xxx-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require

# Database driver: "postgres" for standard PostgreSQL (Docker/local), defaults to Neon serverless (Vercel)
# Only set this when running against a standard PostgreSQL (e.g. docker-compose)
# DB_DRIVER=postgres

# Environment
NODE_ENV=development

# Server Configuration
PORT=3000